// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String                 @id @default(uuid())
  email            String                 @unique
  passwordHash     String
  name             String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  organizationId   String?
  organization     Organization?          @relation(fields: [organizationId], references: [id])
  supportTickets   SupportTicket[]
  supportMessages  SupportTicketMessage[]
  sessions         Session[]
  emailPreferences EmailPreference[]
  termsAcceptedAt  DateTime?

  @@index([organizationId])
}

model Organization {
  id               String               @id @default(uuid())
  name             String               @unique
  users            User[]
  clients          Client[]
  projects         Project[]
  invoices         Invoice[]
  expenses         Expense[]
  quickItems       QuickItem[]
  questionnaires   Questionnaire[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  masterCurrency   String               @default("INR")
  address          String?
  dateFormat       String               @default("dd-MMM-yy")
  status           String               @default("Active") // Active, Blocked
  supportTickets   SupportTicket[]
  templateRequests TemplateRequest[]
  profile          OrganizationProfile?
}

model Client {
  id             String       @id @default(uuid())
  name           String
  email          String
  phone          String?
  status         String       @default("Active") // Active, Inactive, Lead
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  projects               Project[]
  invoices               Invoice[]
  expenses               Expense[]
  questionnaires         Questionnaire[]
  questionnaireResponses QuestionnaireResponse[]

  @@index([organizationId])
  @@unique([email, organizationId])
}

model Project {
  id               String       @id @default(uuid())
  title            String
  description      String?
  startDate        DateTime
  estimatedEndDate DateTime?
  status           String       @default("Planning") // Planning, Active, Completed, On Hold
  clientId         String
  client           Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  invoices       Invoice[]
  expenses       Expense[]
  questionnaires Questionnaire[]

  @@index([clientId])
  @@index([organizationId])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Invoice {
  id             String   @id @default(uuid())
  invoiceNumber  String
  status         String   @default("Draft") // Draft, Sent, Partially Paid, Paid, Overdue, Cancelled
  issueDate      DateTime @default(now())
  dueDate        DateTime
  currency       String   @default("USD")
  subtotal       Float    @default(0)
  taxAmount      Float    @default(0)
  discountAmount Float    @default(0)
  totalAmount    Float    @default(0)
  paidAmount     Float    @default(0)
  exchangeRate   Float    @default(1.0)
  notice         String?
  notes          String?
  terms          String?

  clientId       String
  client         Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  items      InvoiceItem[]
  payments   Payment[]
  activities Activity[]
  expenses   Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([organizationId])
  @@index([projectId])
  @@index([organizationId, status])
}

model InvoiceItem {
  id          String @id @default(uuid())
  description String
  quantity    Int    @default(1)
  unitPrice   Float
  taxRate     Float  @default(0)
  total       Float

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Payment {
  id        String   @id @default(uuid())
  amount    Float
  date      DateTime @default(now())
  method    String // Credit Card, Bank Transfer, Cash, Check
  reference String?

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([invoiceId])
}

model Activity {
  id          String   @id @default(uuid())
  type        String // CREATED, UPDATED, SENT, PAYMENT_RECORDED, PAID, PDF_DOWNLOADED
  description String?
  date        DateTime @default(now())

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Expense {
  id           String   @id @default(uuid())
  description  String
  amount       Float
  date         DateTime @default(now())
  category     String
  status       String   @default("Paid")
  currency     String?
  exchangeRate Float?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([clientId])
  @@index([projectId])
  @@index([invoiceId])
  @@index([organizationId, date])
}

model QuickItem {
  id           String @id @default(uuid())
  name         String // Title or Description of the service/item
  defaultPrice Float  @default(0)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model WaitlistLead {
  id            String   @id @default(uuid())
  fullName      String
  email         String   @unique
  country       String?
  profession    String?
  earningsRange String?
  previousTool  String?
  createdAt     DateTime @default(now())
}

model Questionnaire {
  id            String  @id @default(uuid())
  title         String
  description   String?
  slug          String  @unique
  status        String  @default("Active") // Active, Paused, Closed
  maxResponses  Int?
  responseCount Int     @default(0)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId       String?
  client         Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  fields    QuestionnaireField[]
  responses QuestionnaireResponse[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([clientId])
  @@index([projectId])
  @@index([organizationId, status])
}

model QuestionnaireField {
  id              String        @id @default(uuid())
  questionnaireId String
  questionnaire   Questionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)

  type        String
  label       String
  description String?
  required    Boolean @default(false)
  order       Int
  options     Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([questionnaireId])
}

model QuestionnaireResponse {
  id              String        @id @default(uuid())
  questionnaireId String
  questionnaire   Questionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  answers Json

  createdAt DateTime @default(now())

  @@index([questionnaireId])
  @@index([clientId])
}

model SupportTicket {
  id             String                 @id @default(uuid())
  title          String
  description    String
  status         String                 @default("Open") // Open, In Progress, Resolved
  priority       String                 @default("Medium") // Low, Medium, High
  userId         String
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages       SupportTicketMessage[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([userId])
  @@index([organizationId])
}

model SupportTicketMessage {
  id        String        @id @default(uuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User          @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime      @default(now())

  @@index([ticketId])
  @@index([senderId])
}

model SuperUser {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String?
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model EmailPreference {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  String // e.g., 'Marketing', 'Transactional', 'Alerts'
  optOut    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, category])
  @@index([userId])
}

model EmailQueue {
  id          String   @id @default(uuid())
  to          String
  subject     String
  htmlBody    String
  category    String   @default("Transactional") // To check preferences before sending
  status      String   @default("Pending") // Pending, Processing, Sent, Failed
  attempts    Int      @default(0)
  maxAttempts Int      @default(3)
  lastError   String?
  nextRunAt   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, nextRunAt])
}

model TemplateRequest {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           String // 'Invoice' or 'Expense'
  description    String
  attachmentUrl  String?
  status         String       @default("Pending") // Pending, Completed
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

model OrganizationProfile {
  id             String       @id @default(uuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  phone              String?
  email              String?
  taxId              String? // Generic (e.g. GSTIN, VAT, EIN)
  registrationNumber String? // Generic (e.g. PAN, SSN, Company Reg)
  region             String? // State / Province / Territory

  invoiceFooterNote  String?
  expenseFooterNote  String?
  invoiceTemplate    String  @default("soseki-modern")
  expenseTemplate    String  @default("soseki-modern")
  termsAndConditions String?

  accountNumber String?
  bankName      String?
  routingNumber String? // Generic (e.g. IFSC, Sort Code, Routing Number)
  branch        String?
  upiId         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PageVisit {
  id          String   @id @default(uuid())
  path        String
  referrer    String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmTerm     String?
  utmContent  String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([utmSource])
}