<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>{{subject}}</title>
    <style>
        body { font-family: 'Helvetica Neue', Arial, sans-serif; line-height: 1.6; color: #333; }
        .container { max-width: 600px; margin: 0 auto; padding: 20px; }
        .header { text-align: center; margin-bottom: 20px; }
        .content { background-color: #f9f9f9; padding: 20px; border-radius: 8px; }
        .footer { text-align: center; font-size: 12px; color: #888; margin-top: 20px; }
        .btn { display: inline-block; padding: 10px 20px; background-color: #4F46E5; color: white; text-decoration: none; border-radius: 5px; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h2>Soseki App</h2>
        </div>
        <div class="content">
            <p>Hello {{name}},</p>
            <p>{{{message}}}</p>
            {{#if actionUrl}}
            <p style="text-align: center; margin-top: 30px;">
                <a href="{{actionUrl}}" class="btn">{{actionText}}</a>
            </p>
            {{/if}}
        </div>
        <div class="footer">
            <p>&copy; 2026 Soseki App. All rights reserved.</p>
            {{#if showUnsubscribe}}
            <p>To manage your email preferences, <a href="{{unsubscribeUrl}}">click here</a>.</p>
            {{/if}}
        </div>
    </div>
</body>
</html>
